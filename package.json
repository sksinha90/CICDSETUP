{
  "name": "c_cpe_template",
  "version": "1.0.0",
  "description": "Course Template",
  "private": true,
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9",
    "@cap-js/sqlite": "^2"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "cds": {
    "requires": {
      "[production]": {
        "db": {
          "kind": "hana"
        }
      },
      "[development]": {
        "db": {
          "kind": "sqlite"
        }
      },
      "auth": {
        "kind": "mocked"
      }
    }
  }
}
